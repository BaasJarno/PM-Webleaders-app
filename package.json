{
  "name": "pm-webleaders-app",
  "version": "1.0.9",
  "description": "Desktop app die pm.webleaders.nl toont in Electron",
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/BaasJarno/PM-Webleaders-app.git"
  },
  "bugs": {
    "url": "https://github.com/BaasJarno/PM-Webleaders-app/issues"
  },
  "homepage": "https://github.com/BaasJarno/PM-Webleaders-app#readme",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish=never",
    "dist:win": "electron-builder --win --publish=never",
    "dist:mac": "electron-builder --mac --publish=never",
    "dist:dir": "electron-builder --dir",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "nl.webleaders.pm",
    "productName": "Webleaders PM",
    "publish": {
      "provider": "github",
      "owner": "BaasJarno",
      "repo": "PM-Webleaders-app"
    },
    "directories": {
      "output": "release",
      "buildResources": "."
    },
    "files": [
      "**/*",
      "!**/.github/**",
      "!**/.git/**",
      "!release/**"
    ],
    "asarUnpack": [
      "images/favicon-dark.png",
      "images/favicon-light.png"
    ],
    "win": {
      "icon": "images/favicon-dark.png",
      "signAndEditExecutable": true,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "WebleadersPM-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "icon": "images/favicon-light.png",
      "artifactName": "WebleadersPM-${version}-${arch}.${ext}",
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "extendInfo": {
        "NSHumanReadableCopyright": "Copyright © Webleaders"
      }
    },
    "dmg": {
      "title": "Webleaders PM ${version}"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
